meta {
  name: Refresh
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/refresh
  body: none
  auth: none
}

script:post-response {
  if (res.body.accessToken) {
    bru.setVar("accessToken", res.body.accessToken);
  }
}

docs {
  Rotates the refresh token (sent automatically as an http-only cookie by Bruno's client from
  a prior Login/Register) and issues a fresh access token. The old refresh token is revoked.
}
