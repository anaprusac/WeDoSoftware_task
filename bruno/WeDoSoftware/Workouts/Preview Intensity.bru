meta {
  name: Preview Intensity
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/workouts/preview-intensity
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "type": "Strength",
    "durationMinutes": 95
  }
}

docs {
  Computes the intensity for a (type, duration) pair using the CURRENT user's gender, without
  saving anything. Strength(7) + 90-150min(+2) + Male(0) = 9; Female would be 9.5.
}
