meta {
  name: Get Types
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/workouts/types
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Every workout type with its intensity base point (Cardio=6, Strength=7,
  MobilityFlexibility=3, Rehabilitation=1, FullBody=7, UpperBody=6, LowerBody=6, Core=6,
  Other=5). The frontend's add-workout dropdown and the client-side live-intensity preview
  are built from this.
}
