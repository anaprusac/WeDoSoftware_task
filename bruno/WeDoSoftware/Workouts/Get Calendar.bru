meta {
  name: Get Calendar
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/workouts/calendar?year=2026&month=7
  body: none
  auth: bearer
}

params:query {
  year: 2026
  month: 7
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Distinct dates in the given month that have at least one workout — drives which calendar
  days are shown as selectable.
}
