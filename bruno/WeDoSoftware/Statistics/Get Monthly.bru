meta {
  name: Get Monthly
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/statistics?year=2026&month=7
  body: none
  auth: bearer
}

params:query {
  year: 2026
  month: 7
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Weekly breakdown for the given month: total duration, workout count, and average
  intensity/tiredness per week. Weeks start on Monday and are clipped to the month (so the
  first and last week can be shorter than 7 days).
}
