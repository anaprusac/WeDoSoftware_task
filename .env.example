# Copy this file to `.env` and adjust values. `.env` is gitignored and must never be committed.
# Docker Compose reads `.env` automatically; without it, the defaults below are used.

POSTGRES_DB=wedosoftware
POSTGRES_USER=wedosoftware
POSTGRES_PASSWORD=change_me_local_dev
ASPNETCORE_ENVIRONMENT=Development

# --- Added in later milestones ---
# JWT signing secret (min 32 characters)
# JWT__Secret=

# Gmail SMTP for password-reset emails (M2).
# Use a Google App Password, NEVER your real account password.
# SMTP__Host=smtp.gmail.com
# SMTP__Port=587
# SMTP__Username=your_address@gmail.com
# SMTP__Password=your_16_char_app_password
