# Copy this file to `.env` and adjust values. `.env` is gitignored and must never be committed.
# Docker Compose reads `.env` automatically; without it, the defaults below are used.

# NOTE: Postgres only applies POSTGRES_PASSWORD when the data volume is first created.
# If you change it after the first run, recreate the volume: `docker compose down -v && docker compose up -d`.
POSTGRES_DB=wedosoftware
POSTGRES_USER=wedosoftware
POSTGRES_PASSWORD=wedosoftware_dev_pw
ASPNETCORE_ENVIRONMENT=Development

# Frontend origin used to build the password-reset link in emails.
FRONTEND_BASE_URL=http://localhost:4200

# Gmail SMTP for real password-reset emails (optional, if unset, the reset link is logged instead).
# Use a Google App Password, NEVER your real account password.
# How to get one: Google Account > Security > 2-Step Verification > App passwords.
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# JWT signing secret, only needed to override the dev default in production (min 32 chars).
# JWT_SECRET=
